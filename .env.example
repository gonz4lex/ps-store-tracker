# Environment Configuration Template
# Copy this file to .env and fill in your values
# Note: Never commit .env to version control

# ===== QUICK START: TRY THE DEMO FIRST =====
# Run this to see the dashboard with sample data (no setup needed!):
#   python demo.py
# or with Docker:
#   docker compose up ps_store_tracker_demo

# ===== GMAIL CREDENTIALS (for real data) =====
# Setup steps:
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Select "Mail" and "Windows Computer" (or your device)
#   3. Generate the password and paste it below
EMAIL_ADDRESS=your_email@gmail.com
APP_PASSWORD=your_app_password_here
